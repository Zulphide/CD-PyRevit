<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel Comparison Tool"
        Width="1000" Height="580"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>

        <!-- ListView row style: background from RowColor property,
             blue highlight on selection -->
        <Style x:Key="ResultItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="{Binding RowColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A7BD5"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Step bar -->
        <Border Grid.Row="0" Background="#1A1A1A">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="StepLabel0" Text="1. Load Files"
                           FontSize="11" FontWeight="Bold" Margin="16,0" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StepLabel1" Text="2. Identify Keys"
                           FontSize="11" FontWeight="Bold" Margin="16,0" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StepLabel2" Text="3. Map Columns"
                           FontSize="11" FontWeight="Bold" Margin="16,0" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StepLabel3" Text="4. Results"
                           FontSize="11" FontWeight="Bold" Margin="16,0" Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content panels -->
        <Grid Grid.Row="1">

            <!-- Step 1: Load Files -->
            <ScrollViewer x:Name="PanelFiles" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="440" Margin="0,40,0,40">
                    <TextBlock Text="Load Excel Files" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Select two .xlsx files to compare."
                               FontSize="11" Foreground="#666" Margin="0,0,0,20"/>
                    <TextBlock Text="File A" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="LblPathA" Text="No file selected"
                               FontSize="11" Foreground="#999" Margin="0,0,0,6"/>
                    <Button x:Name="BtnBrowseA" Content="Browse..." HorizontalAlignment="Left"
                            Click="BtnBrowseA_Click"/>
                    <TextBlock Text="File B" FontWeight="SemiBold" Margin="0,20,0,4"/>
                    <TextBlock x:Name="LblPathB" Text="No file selected"
                               FontSize="11" Foreground="#999" Margin="0,0,0,6"/>
                    <Button x:Name="BtnBrowseB" Content="Browse..." HorizontalAlignment="Left"
                            Click="BtnBrowseB_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 2: Identify Keys -->
            <ScrollViewer x:Name="PanelKeys" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="480" Margin="0,40,0,40">
                    <TextBlock Text="Select Tables and Key Columns" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Choose the table (or full sheet) and the unique key column for each file."
                               FontSize="11" Foreground="#666" Margin="0,0,0,20"/>
                    <TextBlock x:Name="LblFileA" Text="File A" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Table / Sheet"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboTblA" Grid.Row="0" Grid.Column="1"
                                  SelectionChanged="ComboTblA_Changed"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Key Column"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboKeyA" Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                    <Border Height="1" Background="#CCC" Margin="0,12,0,12"/>
                    <TextBlock x:Name="LblFileB" Text="File B" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Table / Sheet"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboTblB" Grid.Row="0" Grid.Column="1"
                                  SelectionChanged="ComboTblB_Changed"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Key Column"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboKeyB" Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 3: Map Columns -->
            <Grid x:Name="PanelMapping" Visibility="Collapsed"
                 HorizontalAlignment="Center" Width="700" Margin="0,24,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Map Columns" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Pair columns to compare. Rows set to (skip) are ignored."
                               FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="SemiBold" Foreground="#555"/>
                    <TextBlock Grid.Column="1" Text="File A Column" FontSize="10" FontWeight="SemiBold" Foreground="#555"/>
                    <TextBlock Grid.Column="2" Text="File B Column" FontSize="10" FontWeight="SemiBold" Foreground="#555"/>
                    <TextBlock Grid.Column="3" Text="Output Label" FontSize="10" FontWeight="SemiBold" Foreground="#555"/>
                </Grid>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MappingPanel" Margin="0,0,8,0"/>
                </ScrollViewer>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="BtnAddRow" Content="+ Add Row"
                            Width="90" Margin="0,0,8,0" Click="BtnAddRow_Click"/>
                    <Button x:Name="BtnRemoveRow" Content="- Remove Last"
                            Width="110" Margin="0" Click="BtnRemoveRow_Click"/>
                </StackPanel>
            </Grid>

            <!-- Step 4: Results -->
            <Grid x:Name="PanelResults" Visibility="Collapsed" Margin="16,12,16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Comparison Results" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="14" Height="14" Background="#C6EFCE" Margin="0,0,4,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Full Match" FontSize="11" Margin="0,0,16,0"
                                   VerticalAlignment="Center"/>
                        <Border Width="14" Height="14" Background="#FFC7CE" Margin="0,0,4,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Different (see export for details)" FontSize="11"
                                   Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Border Width="14" Height="14" Background="#FFEB9C" Margin="0,0,4,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Orphaned" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="LblSummary" FontSize="11" Foreground="#555"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- File A -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="LblGridA" Grid.Row="0" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
                        <ListView x:Name="GridA" Grid.Row="1"
                                  ItemContainerStyle="{StaticResource ResultItemStyle}"
                                  SelectionMode="Single"
                                  FontSize="11"
                                  BorderBrush="#CCC" BorderThickness="1"
                                  SelectionChanged="GridA_SelectionChanged">
                            <ListView.View>
                                <GridView x:Name="GridViewA"/>
                            </ListView.View>
                        </ListView>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#E0E0E0"/>

                    <!-- File B -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="LblGridB" Grid.Row="0" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,4"/>
                        <ListView x:Name="GridB" Grid.Row="1"
                                  ItemContainerStyle="{StaticResource ResultItemStyle}"
                                  SelectionMode="Single"
                                  FontSize="11"
                                  BorderBrush="#CCC" BorderThickness="1"
                                  SelectionChanged="GridB_SelectionChanged">
                            <ListView.View>
                                <GridView x:Name="GridViewB"/>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>

        <!-- Nav bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#CCC"
                Background="#F0F0F0" Padding="12,10">
            <DockPanel>
                <TextBlock x:Name="LblStatus" VerticalAlignment="Center"
                           FontSize="11" Foreground="#555"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnBack"    Content="&lt; Back"  Click="BtnBack_Click"/>
                    <Button x:Name="BtnNext"    Content="Next &gt;"  Click="BtnNext_Click"/>
                    <Button x:Name="BtnCompare" Content="Compare"    Click="BtnCompare_Click"/>
                    <Button x:Name="BtnExport"  Content="Export to Excel..."
                            Width="140"          Click="BtnExport_Click"/>
                    <Button x:Name="BtnClose"   Content="Close"      Click="BtnClose_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
