<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mass to Detail Curves"
        Height="460" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <TextBlock Text="Wall thickness parameter" FontWeight="SemiBold"/>
        <ComboBox x:Name="cb_thickness_param" IsEditable="True"
                  Text="ROOM WALL THICKNESS"/>

        <TextBlock Text="Join tolerance (feet)" FontWeight="SemiBold"/>
        <TextBox x:Name="tb_tolerance" Text="0.01"/>

        <CheckBox x:Name="chk_offset_inward" Content="Offset curves inward (toward room center)"
                  IsChecked="False"/>

        <Separator Margin="0,8,0,12"/>

        <CheckBox x:Name="chk_use_filter" Content="Filter masses by parameter value"
                  IsChecked="False" Click="filter_toggled"/>

        <StackPanel x:Name="filter_panel" IsEnabled="False" Margin="20,0,0,0">
            <TextBlock Text="Filter parameter name"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cb_filter_param"
                          Width="310"
                          SelectionChanged="filter_param_changed"/>
                <Button Content="Refresh" Width="68" Height="28"
                        Margin="6,0,0,12" Click="refresh_filter_click"/>
            </StackPanel>
            <TextBlock Text="Filter value"/>
            <ComboBox x:Name="cb_filter_value" IsEditable="True"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Run" Width="90" Height="32"
                    IsDefault="True" Click="run_click"/>
            <Button Content="Cancel" Width="90" Height="32"
                    Margin="8,0,0,0" IsCancel="True" Click="cancel_click"/>
        </StackPanel>

    </StackPanel>
</Window>
